# ============================================
# Beerantum Backend — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local:  mongodb://localhost:27017/beerantum
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/beerantum
MONGODB_URI=mongodb://localhost:27017/beerantum

# JWT Secrets — use long random strings in production!
JWT_SECRET=beerantum_jwt_secret_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=beerantum_refresh_secret_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin seed (first admin user — run `npm run seed` once)
ADMIN_EMAIL=admin@beerantum.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Beerantum Admin
